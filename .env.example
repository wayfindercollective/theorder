# ============================================================
# THE ORDER — environment variables
# Copy to .env.local for local dev. Set in Vercel for prod.
# Site builds and runs fine WITHOUT these — placeholder defaults
# make the offline-first submit queue absorb failed posts gracefully.
# ============================================================

# Wayfinder webhook for this funnel. Slug will be assigned by Wayfinder admin.
VITE_WAYFINDER_WEBHOOK_URL=https://placeholder.invalid/replace-at-launch
VITE_WAYFINDER_API_KEY=

# Funnel slug + site domain — sent in payload for routing / attribution.
VITE_FUNNEL_SLUG=the-order
VITE_SITE_DOMAIN=theorder.placeholder

# PostHog (optional — no-op if absent).
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
