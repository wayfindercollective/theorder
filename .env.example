# ============================================================
# THE ORDER — environment variables
# Copy to .env.local for local dev. Set in Vercel for prod.
# Site builds and runs fine WITHOUT these — placeholder defaults
# make the offline-first submit queue absorb failed posts gracefully.
# ============================================================

# Wayfinder webhook for this funnel. Slug will be assigned by Wayfinder admin.
VITE_WAYFINDER_WEBHOOK_URL=https://placeholder.invalid/replace-at-launch
VITE_WAYFINDER_API_KEY=

# Funnel slug + site domain — sent in payload for routing / attribution.
VITE_FUNNEL_SLUG=the-order
VITE_SITE_DOMAIN=theorder.placeholder

# PostHog (optional — no-op if absent).
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ============================================================
# ADMIN / CMS (/admin route)
# Required for /admin to work. Set in Vercel → Project → Environment Variables.
# Do NOT prefix with VITE_ — these are server-side only.
# ============================================================

# Password Peter uses to log in at /admin
ADMIN_PASSWORD=

# Random 32-byte hex string used to sign JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_JWT_SECRET=

# GitHub Personal Access Token with `repo` scope.
# Create at: https://github.com/settings/tokens?type=beta
# Scope: contents read+write on this repo only.
GITHUB_TOKEN=

# Owner/repo for content commits.
GITHUB_REPO=wayfindercollective/theorder

# Branch the CMS commits to. Defaults to "main" if unset.
GITHUB_BRANCH=main

# Vercel Blob token — auto-populated when you enable Blob in Vercel dashboard.
# Storage → Connect Blob Store → set as BLOB_READ_WRITE_TOKEN.
BLOB_READ_WRITE_TOKEN=
